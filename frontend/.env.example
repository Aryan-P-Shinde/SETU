# ─────────────────────────────────────────────────────────────────────────────
# SETU Frontend — Environment Variables (Vite)
# Copy to .env and fill in real values. Never commit .env to git.
# All variables must be prefixed with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# Local dev: points to your running FastAPI server (make dev)
# Production: your Cloud Run service URL
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Firebase (frontend SDK) ───────────────────────────────────────────────────
# All values from: Firebase Console → Project Settings → Your apps → Web app
# If you haven't added a web app yet: click "Add app" → Web → register it.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=1:000000000000:web:your-app-id

# ── Google Maps (optional — needed for the Map view tab) ──────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Enable "Maps JavaScript API" for your project first.
# If left empty, the map tab shows a placeholder message (everything else works).
VITE_GOOGLE_MAPS_KEY=your-google-maps-js-api-key
